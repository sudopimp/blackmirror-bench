{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/waitdeadai/blackmirror-bench/schema/evidence.schema.json",
  "title": "BlackMirror-Bench Evidence Entry",
  "type": "object",
  "required": [
    "evidence_id",
    "thesis_id",
    "url",
    "title",
    "accessed_at",
    "tier",
    "supports_axes",
    "excerpt"
  ],
  "additionalProperties": false,
  "properties": {
    "evidence_id": { "type": "string" },
    "thesis_id": { "type": "string" },
    "url": { "type": "string", "format": "uri" },
    "title": { "type": "string" },
    "accessed_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "tier": {
      "type": "string",
      "enum": ["L1", "L2", "L3"]
    },
    "supports_axes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "THESIS_POSS",
          "AI_EXEC",
          "TRL_comp",
          "SYS",
          "ECON",
          "SOC",
          "FID"
        ]
      },
      "minItems": 1
    },
    "excerpt": { "type": "string", "minLength": 10 },
    "notes": { "type": "string" }
  }
}
