{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/waitdeadai/blackmirror-bench/schema/model_task.schema.json",
  "title": "BlackMirror-Bench Model Task",
  "type": "object",
  "required": [
    "task_id",
    "track",
    "thesis_id",
    "prompt",
    "split",
    "safety_class"
  ],
  "additionalProperties": false,
  "properties": {
    "task_id": { "type": "string" },
    "track": {
      "type": "string",
      "enum": ["T1", "T2", "T3", "T4", "T5"]
    },
    "thesis_id": { "type": "string" },
    "prompt": { "type": "string", "minLength": 20 },
    "split": {
      "type": "string",
      "enum": ["public_dev", "public_test", "private_test"]
    },
    "safety_class": {
      "type": "string",
      "enum": ["analysis", "boundary", "update"]
    },
    "gold_ref": { "type": "string" },
    "metadata": { "type": "object" }
  }
}
